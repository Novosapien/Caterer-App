# WhatsApp Gig Agent — environment variables
# Copy to .env for local dev; set as Cloud Run env vars / secrets in production.

# --- Anthropic (Claude Sonnet 5) ---
ANTHROPIC_API_KEY=
# Model id. Defaults to claude-sonnet-5 (resolves to the latest Sonnet).
ANTHROPIC_MODEL=claude-sonnet-5

# --- Twilio (WhatsApp transport, sandbox) ---
# From the Twilio Console. TWILIO_WHATSAPP_FROM is the sandbox number below.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+17372583478

# --- Supabase ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Postgres connection string for the LangGraph checkpointer.
# Use Supabase > Connect > Session pooler URI (port 5432) with your DB password, e.g.
# postgresql://postgres.<ref>:PASSWORD@aws-1-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=

# --- Service auth (shared with the Next.js /notify caller) ---
NOTIFY_SHARED_SECRET=

# --- Optional observability ---
LANGSMITH_API_KEY=
