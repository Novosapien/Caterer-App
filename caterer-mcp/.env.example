# Supabase project (same one the Caterer Dubai app uses).
# The service-role key is SERVER-ONLY and bypasses RLS — keep it secret.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxxxxxxxxxxx

# Which chef this MCP session acts as (their profiles.id). Defaults to the demo
# chef (Yusuf Rahman) if unset.
CATERER_PROFILE_ID=11111111-1111-1111-1111-111111111111
